# =============================================================================
# Levi Lael — Environment variables
# =============================================================================
# Copie este arquivo para .env.local e preencha os valores reais.
# Sem nenhuma chave preenchida, o site roda em modo "stubs": formulários
# logam no console, IA usa análise mock e blog usa conteúdo local.
# =============================================================================

# Site
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="Levi Lael"

# CTA de agendamento — se vazio, fallback para mailto:hello@levilael.com.br
NEXT_PUBLIC_CALCOM_URL=""

# Social (opcionais — fallbacks reais já configurados em lib/site.ts)
NEXT_PUBLIC_LINKEDIN_URL=""
NEXT_PUBLIC_GITHUB_URL=""

# Anthropic (Claude) — diagnose AI analysis
ANTHROPIC_API_KEY=""

# Supabase — persistência de diagnoses, contatos e assinantes
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Resend — e-mails transacionais
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Levi Lael <hello@levilael.com.br>"
INTERNAL_NOTIFICATION_EMAIL="hello@levilael.com.br"

# Notion — CMS de blog
NOTION_API_KEY=""
NOTION_DATABASE_ID_BLOG=""
NOTION_WEBHOOK_SECRET=""
