# =============================================================================
# Levi Lael — Environment variables
# =============================================================================
# Copie este arquivo para .env.local e preencha os valores reais.
# Sem nenhuma chave preenchida, o site roda em modo "stubs": formulários
# logam no console, IA usa análise mock e blog usa conteúdo local.
# =============================================================================

# Site
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="Levi Lael"

# CTA de agendamento — se vazio, fallback para mailto:hello@levilael.com.br
NEXT_PUBLIC_CALCOM_URL=""

# Social (opcionais — fallbacks reais já configurados em lib/site.ts)
NEXT_PUBLIC_LINKEDIN_URL=""
NEXT_PUBLIC_GITHUB_URL=""

# Anthropic (Claude) — diagnose AI analysis
ANTHROPIC_API_KEY=""

# Supabase — persistência de diagnoses, contatos e assinantes
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Resend — e-mails transacionais
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Levi Lael <hello@levilael.com.br>"
INTERNAL_NOTIFICATION_EMAIL="hello@levilael.com.br"

# Telegram — notificações internas (form de agendamento dispara aqui).
# Sem essas vars, o form ainda salva no banco mas ninguém é notificado.
# Setup:
#   1. /BotFather no Telegram → /newbot → copia o token aqui.
#   2. Cada destinatário manda /start pro bot, depois abre
#      https://api.telegram.org/bot<TOKEN>/getUpdates e pega o "chat":{"id":...}.
#   3. TELEGRAM_CHAT_IDS = ids separados por vírgula.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_IDS=""

# Notion — CMS de blog
NOTION_API_KEY=""
NOTION_DATABASE_ID_BLOG=""
NOTION_WEBHOOK_SECRET=""

# Cron (Vercel envia automaticamente quando configurado em vercel.json:crons)
# Localmente: passe via header Authorization: Bearer $CRON_SECRET
# Gere: openssl rand -hex 32
CRON_SECRET=""

# HMAC pra assinar tokens de unsubscribe (links nos e-mails 2-6)
# Gere: openssl rand -hex 32
UNSUBSCRIBE_SECRET=""

# =============================================================================
# Admin (editorial pipeline) — /admin
# =============================================================================
# Senha em texto pra logar em /admin. Comparada constant-time.
ADMIN_PASSWORD=""

# Segredo HMAC pra assinar o cookie de sessão admin.
# Gere: openssl rand -hex 32
ADMIN_SESSION_SECRET=""

# Limites de custo IA pra avisos no admin (Phase 5).
ADMIN_DAILY_COST_LIMIT_BRL="5"
ADMIN_MONTHLY_COST_LIMIT_BRL="100"

# =============================================================================
# Marketing tracking (Meta Pixel + CAPI, Google Ads, GA4)
# =============================================================================
# Sem essas vars, Pixel/gtag/CAPI ficam OFF — site funciona, conversões não
# são registradas nas plataformas. Tracking interno (lib/tracking.ts) continua.
# =============================================================================

# Meta Pixel — ID público no Business Manager → Pixels.
NEXT_PUBLIC_META_PIXEL_ID=""

# Meta Conversions API — token de longa duração no Events Manager → Settings.
META_CAPI_ACCESS_TOKEN=""

# Opcional: code de evento de teste pra ver dispatches no "Test Events" sem
# poluir Overview. Quando setado, eventos viram test events.
META_CAPI_TEST_EVENT_CODE=""

# Google Ads — ID da conta (formato AW-XXXXXXXXXX).
NEXT_PUBLIC_GOOGLE_ADS_ID=""

# Conversion send_to labels (formato AW-XXX/yyyyyyyyy). Pega no Google Ads →
# Conversões → click na ação → "Configuração da tag" → "Use o Gerenciador de
# tags". Se vazio, o disparo dessa conversão é skipado silenciosamente.
NEXT_PUBLIC_GADS_CONVERSION_LEAD=""
NEXT_PUBLIC_GADS_CONVERSION_HOT_LEAD=""
NEXT_PUBLIC_GADS_CONVERSION_CALL_SCHEDULED=""

# Google Analytics 4 — Measurement ID (formato G-XXXXXXXXXX).
NEXT_PUBLIC_GA4_MEASUREMENT_ID=""
